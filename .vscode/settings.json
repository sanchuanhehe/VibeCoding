{
  "esbonio.server.enabled": true,
  "esbonio.server.pythonPath": "${command:python.interpreterPath}",
  "esbonio.sphinx.pythonCommand": {
    "command": [
      "${command:python.interpreterPath}",
      "-S"
    ],
    "cwd": "${workspaceFolder}"
  },
  "esbonio.sphinx.buildCommand": [
    "${command:python.interpreterPath}",
    "-m",
    "sphinx",
    "-M",
    "dirhtml",
    "docs",
    "docs/_build"
  ]
}
