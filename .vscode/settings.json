{
  "esbonio.server.enabled": true,
  "esbonio.server.pythonPath": "/usr/bin/python",
  "esbonio.sphinx.pythonCommand": {
    "command": [
      "/usr/bin/python",
      "-S"
    ],
    "cwd": "${workspaceFolder}"
  },
  "esbonio.sphinx.buildCommand": [
    "/usr/bin/python",
    "-m",
    "sphinx",
    "-M",
    "dirhtml",
    "docs",
    "docs/_build"
  ]
}
